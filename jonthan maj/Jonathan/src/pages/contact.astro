---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ContactForm from '../components/ContactForm.astro';
import site from '../data/site.json';
import { buildHowToJsonLd } from '../utils/structured-data';

type HowToDevis = {
  name: string;
  description: string;
  totalTime?: string;
  steps: { name: string; text: string }[];
};

const howToDevis = (site as typeof site & { howToDevis?: HowToDevis }).howToDevis;
const extraContactJsonLd =
  howToDevis?.steps?.length ?
    [
      buildHowToJsonLd({
        name: howToDevis.name,
        description: howToDevis.description,
        ...(howToDevis.totalTime ? { totalTime: howToDevis.totalTime } : {}),
        steps: howToDevis.steps,
      }),
    ]
  : [];
---

<Layout
  title="Contact"
  description="Contactez Marant Jonathan à Saint-Ambroix : menuiserie, ébénisterie, charpente, zinguerie et couverture. Devis et conseils pour particuliers et professionnels."
  keywords={`contact ${site.marque}, devis menuiserie Saint-Ambroix, devis charpente Gard, artisan bois ${site.adresse.ville}`}
  extraJsonLd={extraContactJsonLd}
>
  <section class="page-header">
    <div class="container">
      <Breadcrumb crumbs={[{ label: 'Contact' }]} />
      <p class="overline reveal">Échangeons</p>
      <h1 class="reveal">Contact</h1>
      <p class="page-intro text-dim reveal">
        Un projet de menuiserie, de charpente ou de couverture ?
        Contactez-nous pour un échange personnalisé et un devis gratuit.
      </p>
    </div>
  </section>

  <ContactForm />
</Layout>

<style>
  .page-header {
    padding-top: calc(var(--header-height) + var(--space-xl));
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .page-header h1 {
    margin-block: .5rem var(--space-sm);
  }

  .page-intro {
    font-size: 1.05rem;
  }
</style>
