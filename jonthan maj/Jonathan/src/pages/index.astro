---
import { withBase } from '../utils/base';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MetierSection from '../components/MetierSection.astro';
import ProjetCard from '../components/ProjetCard.astro';
import ContactForm from '../components/ContactForm.astro';
import AvisSection from '../components/AvisSection.astro';
import projets from '../data/projets.json';
import site from '../data/site.json';
import { buildFaqPageJsonLd, buildMetiersServiceItemListJsonLd } from '../utils/structured-data';

const vedettes = projets.filter((p) => p.vedette);

const faqEntries = (site as typeof site & { faq?: { question: string; answer: string }[] }).faq;
const siteHref = Astro.site!.href;
const serviceUrlForMetierId = (id: string) =>
  new URL(
    `${withBase('/realisations').replace(/^\//, '')}?filtre=${encodeURIComponent(id)}`,
    Astro.site!
  ).href;

const servicesMetiersJsonLd = buildMetiersServiceItemListJsonLd(
  siteHref,
  serviceUrlForMetierId,
  site.metiers
);

const extraHomeJsonLd = [
  ...(faqEntries?.length ? [buildFaqPageJsonLd(faqEntries)] : []),
  servicesMetiersJsonLd,
];

const heroPreloadHref = new URL(
  withBase('/images/projets/escalier-colimacon/01.webp').replace(/^\//, ''),
  Astro.site!
).href;
---

<Layout
  title="Accueil"
  fullTitle="Marant Jonathan — menuisier, charpentier, ebeniste, couvreur & zingueur à Saint-Ambroix (Gard)"
  description="Marant Jonathan — menuiserie, ébénisterie, charpente, zinguerie et couverture à Saint-Ambroix. Savoir-faire artisanal pour particuliers et professionnels."
  ogImageAlt="Marant Jonathan — menuiserie, charpente, zinguerie et couverture à Saint-Ambroix (Gard)"
  extraJsonLd={extraHomeJsonLd}
  preloadImageHref={heroPreloadHref}
  introSplash
>
  <Hero />

  <MetierSection />

  <section class="section portfolio-section" id="realisations-preview" aria-labelledby="portfolio-title">
    <div class="portfolio-header reveal">
      <span class="portfolio-rule" aria-hidden="true"></span>
      <div class="portfolio-header-inner">
        <p class="overline portfolio-overline">Portfolio</p>
        <h2 id="portfolio-title" class="portfolio-title">
          <svg class="portfolio-icon" viewBox="0 0 24 24" width="28" height="28" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <span class="portfolio-title-text">Réalisations récentes</span>
        </h2>
        <p class="portfolio-lead">
          Découvrez une sélection de nos chantiers.
        </p>
      </div>
      <span class="portfolio-rule" aria-hidden="true"></span>
    </div>

    <div class="container">
      <div class="projets-preview-grid">
        {vedettes.map((p, i) => (
          <ProjetCard
            slug={p.slug}
            titre={p.titre}
            categorie={p.categorie}
            annee={p.annee}
            lieu={p.lieu}
            couverture={p.couverture}
            index={i}
          />
        ))}
      </div>
      <div class="cta-center reveal">
        <a href={withBase('/realisations')} class="btn">Voir tous les projets</a>
      </div>
    </div>
  </section>

  <AvisSection />

  <!-- Testimonial / Engagement band -->
  <section class="section engagement">
    <div class="container engagement-inner reveal">
      <blockquote>
        <p>&laquo; Le bois est une matière vivante. Chaque pièce raconte une histoire,
        chaque assemblage est un geste transmis de génération en génération. &raquo;</p>
        <cite>— Marant Jonathan</cite>
      </blockquote>
    </div>
  </section>

  <ContactForm />
</Layout>

<style>
  /* ── Section portfolio ───────────────────────────────── */
  .portfolio-section {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  /* Bandeau d'en-tête centré avec lignes décoratives */
  .portfolio-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-inline: var(--space-md);
    max-width: var(--max-w);
    margin: 0 auto var(--space-lg);
  }

  .portfolio-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--accent), transparent);
    opacity: .45;
  }

  .portfolio-header-inner {
    text-align: center;
    flex-shrink: 0;
    max-width: min(100%, 580px);
    width: 100%;
  }

  .portfolio-overline {
    margin-bottom: .5rem;
  }

  .portfolio-title {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: .55rem .65rem;
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 300;
    line-height: 1.1;
    margin: 0 auto;
    max-width: 100%;
  }

  .portfolio-title-text {
    text-align: center;
  }

  .portfolio-icon {
    color: var(--accent);
    flex-shrink: 0;
    width: clamp(22px, 4vw, 32px);
    height: clamp(22px, 4vw, 32px);
  }

  .portfolio-lead {
    margin: .65rem auto 0;
    max-width: 52ch;
    font-size: .9rem;
    color: var(--text-dim);
    line-height: 1.65;
  }

  /* Grille projets */
  .projets-preview-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .projets-preview-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cta-center {
    text-align: center;
    margin-top: var(--space-lg);
  }

  /* Mobile : pas de traits dorés, bloc titre pleine largeur et centré */
  @media (max-width: 767px) {
    .portfolio-rule {
      display: none;
    }

    .portfolio-header {
      display: block;
      padding-inline: var(--space-sm);
      margin-bottom: var(--space-md);
    }

    .portfolio-header-inner {
      max-width: 100%;
    }

    .portfolio-title {
      flex-direction: column;
      gap: .45rem;
    }

    .portfolio-icon {
      width: 36px;
      height: 36px;
    }
  }

  /* ── Engagement band ─────────────────────────────────── */
  .engagement {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .engagement-inner {
    text-align: center;
    max-width: 800px;
    margin-inline: auto;
  }

  blockquote p {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.5;
    color: var(--text);
    max-width: none;
  }

  cite {
    display: block;
    margin-top: var(--space-sm);
    font-size: .85rem;
    font-style: normal;
    letter-spacing: .1em;
    color: var(--accent);
  }
</style>
