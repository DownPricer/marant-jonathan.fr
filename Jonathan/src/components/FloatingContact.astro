---
import site from '../data/site.json';
import { telHref, whatsAppPathDigits } from '../utils/phone';

const raw = (site.telephone ?? '').trim();
const tel = raw ? telHref(raw) : '';
const waDigits = raw ? whatsAppPathDigits(raw) : '';
const show = Boolean(tel && waDigits);
---

{
  show && (
    <nav class="floating-contact" aria-label="Contact rapide">
      <div class="floating-contact__inner">
        <a href={`tel:${tel}`} class="fc-btn fc-btn--call" aria-label={`Appeler au ${raw}`}>
          <svg class="fc-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Appeler</span>
        </a>
        <a
          href={`https://wa.me/${waDigits}`}
          class="fc-btn fc-btn--wa"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Contacter sur WhatsApp"
        >
          <svg class="fc-icon fc-icon--wa" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          <span>WhatsApp</span>
        </a>
      </div>
    </nav>
  )
}

<style>
  .floating-contact {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 88;
    padding: 0.65rem 1rem calc(0.65rem + env(safe-area-inset-bottom, 0px));
    pointer-events: none;
  }

  .floating-contact__inner {
    pointer-events: auto;
    max-width: 22rem;
    margin-inline: auto;
    display: flex;
    gap: 0.65rem;
    padding: 0.5rem 0.65rem;
    background: rgba(10, 10, 10, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(184, 149, 106, 0.22);
    border-radius: 999px;
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.35);
  }

  .fc-btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.65rem;
    padding: 0.4rem 0.85rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim, #9a9590);
    border-radius: 999px;
    border: 1px solid rgba(154, 149, 144, 0.35);
    background: rgba(26, 25, 23, 0.6);
    transition:
      color 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease,
      transform 0.2s ease;
  }

  .fc-btn:hover,
  .fc-btn:focus-visible {
    color: var(--text, #f5f0eb);
    border-color: rgba(184, 149, 106, 0.55);
    background: rgba(42, 41, 38, 0.85);
    transform: translateY(-1px);
  }

  .fc-btn--call:hover,
  .fc-btn--call:focus-visible {
    border-color: rgba(184, 149, 106, 0.75);
    color: var(--accent, #b8956a);
  }

  .fc-btn--wa:hover .fc-icon--wa,
  .fc-btn--wa:focus-visible .fc-icon--wa {
    color: #25d366;
  }

  .fc-btn--wa:hover,
  .fc-btn--wa:focus-visible {
    border-color: rgba(37, 211, 102, 0.35);
    color: var(--text, #f5f0eb);
  }

  .fc-icon {
    flex-shrink: 0;
    opacity: 0.9;
  }

  .fc-icon--wa {
    color: rgba(37, 211, 102, 0.85);
    transition: color 0.25s ease;
  }

  @media (min-width: 480px) {
    .floating-contact__inner {
      max-width: 24rem;
      gap: 0.85rem;
      padding: 0.55rem 0.85rem;
    }

    .fc-btn {
      font-size: 0.74rem;
      min-height: 2.75rem;
    }
  }
</style>
