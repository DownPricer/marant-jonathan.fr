---
import site from '../data/site.json';
import { telHref } from '../utils/phone';
import { withBase } from '../utils/base';
import GoogleAvisLink from './GoogleAvisLink.astro';

interface Props {
  /** Bandeau musique juste au-dessus : évite un double grand espacement */
  musicBandAbove?: boolean;
}

const { musicBandAbove = false } = Astro.props;
---

<footer class:list={['site-footer', { 'site-footer--after-music': musicBandAbove }]}>
  <div class="container footer-inner">
    <div class="footer-brand">
      <picture>
        <source srcset={`${withBase('/logo/hero-logo-mj-marque.webp')}?v=3`} type="image/webp" />
        <img
          class="footer-logo"
          src={`${withBase('/logo/hero-logo-mj-marque.png')}?v=3`}
          alt=""
          width="800"
          height="800"
          decoding="async"
        />
      </picture>
      <span class="footer-name">{site.nom}</span>
      <span class="footer-sub">{site.sousTitre}</span>
    </div>

    <div class="footer-contact">
      <div class="footer-contact__lines">
        {site.telephone ? (
          <a href={`tel:${telHref(site.telephone)}`}>{site.telephone}</a>
        ) : (
          <span class="footer-muted">{site.telephoneHint}</span>
        )}
        {site.email ? (
          <a href={`mailto:${site.email}`}>{site.email}</a>
        ) : null}
      </div>
      <div class="footer-contact__badges" aria-label="Réseaux sociaux et annuaires">
        {(site as typeof site & { facebookUrl?: string }).facebookUrl && (
          <a
            class="footer-social footer-social--facebook"
            href={(site as typeof site & { facebookUrl?: string }).facebookUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook — Marant Jonathan Menuiserie"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            <span>Facebook</span>
          </a>
        )}
        {site.pagesJaunesUrl && (
          <a
            class="footer-pj"
            href={site.pagesJaunesUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Pages Jaunes — fiche entreprise"
          >
            <img
              src={withBase('/images/pages-jaunes-logo.svg')}
              alt=""
              width="176"
              height="36"
              decoding="async"
            />
          </a>
        )}
        <GoogleAvisLink />
      </div>
    </div>

    <div class="footer-legal">
      <nav class="footer-legal__links" aria-label="Liens légaux">
        <a href={withBase('/mentions-legales/')}>Mentions légales</a>
        <span class="footer-legal__sep" aria-hidden="true">·</span>
        <a href={withBase('/politique-confidentialite/')}>Politique de confidentialité</a>
      </nav>
      <span>&copy; {new Date().getFullYear()} {site.nom} — Tous droits réservés</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding-block: var(--space-lg);
    margin-top: var(--space-xl);
  }

  .site-footer.site-footer--after-music {
    margin-top: var(--space-md);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .35rem;
  }

  .footer-logo {
    height: 64px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
    object-position: center;
    background: transparent;
    opacity: .55;
  }

  @media (max-width: 768px) {
    .footer-logo {
      height: 104px;
      max-width: 280px;
    }
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 300;
    letter-spacing: .06em;
  }

  .footer-sub {
    display: block;
    font-size: .65rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    font-size: .85rem;
    color: var(--text-dim);
  }

  .footer-contact__lines {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    line-height: 1.45;
  }

  .footer-contact__badges {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.65rem 0.85rem;
  }

  .footer-social {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--text-dim);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .footer-social:hover {
    color: var(--accent);
    transform: translateY(-1px);
  }

  .footer-social svg {
    flex-shrink: 0;
  }

  .footer-contact a:hover {
    color: var(--accent);
  }

  .footer-pj {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    opacity: 0.92;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .footer-pj:hover {
    opacity: 1;
    transform: translateY(-1px);
  }

  .footer-pj img {
    height: 22px;
    width: auto;
    display: block;
  }

  .footer-muted {
    max-width: 220px;
    text-align: center;
    line-height: 1.5;
  }

  .footer-legal {
    font-size: .75rem;
    color: var(--text-dim);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .4rem;
  }

  .footer-legal__links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: .35rem .5rem;
  }

  .footer-legal__links a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-legal__links a:hover {
    color: var(--accent);
  }

  .footer-legal__sep {
    opacity: .5;
  }
</style>
