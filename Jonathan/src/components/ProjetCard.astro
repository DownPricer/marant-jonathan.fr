---
import { withBase } from '../utils/base';
import { labelCategorie } from '../utils/categories';

interface Props {
  slug: string;
  titre: string;
  categorie: string;
  annee: string;
  lieu: string;
  couverture: string;
  index?: number;
}

const { slug, titre, categorie, annee, lieu, couverture, index = 0 } = Astro.props;
const imgSrc = withBase(`/images/projets/${slug}/${couverture.replace(/\.(jpe?g|png)$/i, '.webp')}`);
const categorieLabel = labelCategorie(categorie);
---

<a
  href={withBase(`/realisations/${slug}`)}
  class="projet-card reveal"
  style={`transition-delay: ${index * .08}s`}
>
  <div class="projet-img-wrap">
    <div class="projet-img" style={`background-image:url(${imgSrc})`}></div>
    <div class="projet-overlay">
      <span class="projet-voir">Voir le projet</span>
    </div>
  </div>
  <div class="projet-info">
    <span class="overline">{categorieLabel}</span>
    <h3>{titre}</h3>
    <p class="text-dim">{lieu} — {annee}</p>
  </div>
</a>

<style>
  .projet-card {
    display: block;
    overflow: hidden;
  }

  .projet-img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/2;
    background: var(--surface);
  }

  .projet-img {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform .7s cubic-bezier(.4, 0, .2, 1);
  }

  .projet-card:hover .projet-img {
    transform: scale(1.06);
  }

  .projet-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, .5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity .4s;
  }

  .projet-card:hover .projet-overlay {
    opacity: 1;
  }

  .projet-voir {
    font-size: .8rem;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--text);
    padding: .6rem 1.6rem;
    border: 1px solid var(--text);
    transition: background var(--transition), color var(--transition);
  }

  .projet-voir:hover {
    background: var(--text);
    color: var(--bg);
  }

  .projet-info {
    padding: var(--space-sm) 0;
    display: flex;
    flex-direction: column;
    gap: .3rem;
  }

  .projet-info h3 {
    font-weight: 400;
    font-size: 1.15rem;
  }

  .projet-info p {
    font-size: .85rem;
  }
</style>
