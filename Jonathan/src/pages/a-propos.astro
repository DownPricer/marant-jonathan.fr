---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import site from '../data/site.json';
import { withBase } from '../utils/base';

const nomParts = site.nom.trim().split(/\s+/);
const prenomAbout = nomParts[0] ?? site.nom;
const nomFamilleAbout = nomParts.length > 1 ? nomParts.slice(1).join(' ') : '';
---

<Layout title="À propos" description="Marant Jonathan, menuisier, charpentier, ebeniste, couvreur et zingueur à Saint-Ambroix (30). Menuiserie, ébénisterie, charpente, zinguerie et couverture pour particuliers et professionnels.">
  <section class="page-header">
    <div class="container">
      <Breadcrumb crumbs={[{ label: 'À propos' }]} />
      <p class="overline reveal">L'artisan</p>
      <h1 class="reveal">À propos</h1>
    </div>
  </section>

  <section class="section about-body">
    <div class="container about-grid">
      <div class="about-portrait reveal">
        <div
          class="portrait-img portrait-img--avatar"
          style={`background-image:url(${JSON.stringify(withBase('/logo/avatar3.png'))})`}
          role="img"
          aria-label="Portrait illustré — Marant Jonathan, artisan"
        ></div>
      </div>

      <div class="about-text">
        <div class="about-headline reveal">
          <h2 class="about-name">
            <span class="about-name__given">{prenomAbout}</span>
            {nomFamilleAbout && (
              <>
                {' '}
                <span class="about-name__family">{nomFamilleAbout}</span>
              </>
            )}
          </h2>
          <p class="about-role">{site.sousTitre}</p>
        </div>
        <p class="reveal">{site.aPropos.paragraphe1}</p>
        <p class="reveal">{site.aPropos.paragraphe2}</p>

        <div class="certifications reveal">
          <h3>Certifications & garanties</h3>
          <ul>
            {site.aPropos.certifications.map((c) => (
              <li>{c}</li>
            ))}
          </ul>
        </div>

        <div class="zone reveal">
          <h3>Zone d'intervention</h3>
          <p class="text-dim">{site.zone}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section values">
    <div class="container">
      <div class="grid-3">
        <div class="value-card reveal">
          <span class="value-number">01</span>
          <h3>Excellence</h3>
          <p class="text-dim">Chaque détail compte. Les assemblages traditionnels, les finitions manuelles et le choix des matériaux reflètent un engagement sans compromis envers la qualité.</p>
        </div>
        <div class="value-card reveal">
          <span class="value-number">02</span>
          <h3>Durabilité</h3>
          <p class="text-dim">Des réalisations conçues pour traverser le temps. Bois issus de forêts gérées durablement, techniques éprouvées et matériaux nobles.</p>
        </div>
        <div class="value-card reveal">
          <span class="value-number">03</span>
          <h3>Sur mesure</h3>
          <p class="text-dim">Chaque projet est unique. L'écoute attentive de vos besoins et la création sur mesure garantissent un résultat qui vous ressemble.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding-top: calc(var(--header-height) + var(--space-xl));
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .page-header h1 {
    margin-top: .5rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-xl);
  }

  @media (max-width: 1023px) {
    .page-header {
      /* Évite le chevauchement avec le header fixe (hauteur réelle > --header-height) + encoche iOS */
      padding-top: calc(var(--header-height) + var(--space-md) + env(safe-area-inset-top, 0px));
      padding-bottom: var(--space-sm);
    }

    .page-header h1 {
      margin-top: .35rem;
      font-size: clamp(0.82rem, 2.2vw + 0.62rem, 1.26rem);
      line-height: 1.2;
      letter-spacing: 0.01em;
    }

    .about-body {
      padding-block: var(--space-md);
    }

    .about-grid {
      gap: var(--space-md);
    }

    .about-text {
      min-width: 0;
    }

    .about-headline {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      align-items: center;
      text-align: center;
      margin-bottom: var(--space-xs);
      width: 100%;
      min-width: 0;
    }

    .about-name {
      font-family: var(--font-hero-title);
      font-size: clamp(1.85rem, 5.2vw + 0.65rem, 2.65rem);
      font-weight: 700;
      font-style: normal;
      line-height: 1.08;
      margin: 0;
      letter-spacing: -0.035em;
      text-wrap: balance;
    }

    .about-text p.about-role {
      margin: 0;
      padding: 0;
      font-family: var(--font-body);
      font-size: clamp(1rem, 2vw, 1.3rem);
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      line-height: 1.35;
      max-width: none;
      text-align: center;
    }

    @media (min-width: 768px) {
      .about-text p.about-role {
        white-space: nowrap;
        letter-spacing: clamp(0.1em, 0.09em + 0.2vw, 0.18em);
        font-size: clamp(0.78rem, 1.05vw, 1.05rem);
      }
    }

    .values {
      padding-block: var(--space-md);
    }
  }

  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    }

    .about-headline {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      align-items: flex-start;
      text-align: left;
      width: 100%;
      min-width: 0;
    }

    .about-name {
      font-family: var(--font-hero-title);
      margin: 0 0 var(--space-xs);
      font-size: clamp(2.25rem, 3.2vw + 1rem, 3.35rem);
      font-weight: 700;
      font-style: normal;
      letter-spacing: -0.035em;
      line-height: 1.05;
      text-wrap: balance;
    }

    .about-text p.about-role {
      font-family: var(--font-body);
      font-size: clamp(0.78rem, 1.05vw, 1.05rem);
      font-weight: 400;
      letter-spacing: clamp(0.1em, 0.09em + 0.2vw, 0.18em);
      text-transform: uppercase;
      color: var(--accent);
      white-space: nowrap;
      margin: 0;
      padding: 0;
      text-align: left;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }

  .portrait-img {
    width: 100%;
    aspect-ratio: 3/4;
    background-size: cover;
    background-position: center;
    background-color: var(--surface);
  }

  /* Portrait (avatar illustré), format vertical */
  .portrait-img--avatar {
    aspect-ratio: 957 / 1120;
    max-width: min(100%, 380px);
    margin-inline: auto;
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center 18%;
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  @media (max-width: 1023px) {
    /* Cercle : clip sur le bloc parent (meilleur rendu WebKit qu’un seul div) */
    .about-portrait {
      width: min(11.5rem, 72vw);
      max-width: 100%;
      aspect-ratio: 1;
      margin-inline: auto;
      border-radius: 50%;
      overflow: hidden;
      border: 1px solid var(--border);
      flex-shrink: 0;
    }

    .portrait-img--avatar {
      width: 100%;
      height: 100%;
      min-height: 100%;
      aspect-ratio: unset;
      max-width: none;
      margin-inline: 0;
      border-radius: 0;
      border: none;
      background-position: center 22%;
    }
  }

  @media (min-width: 1024px) {
    .portrait-img--avatar {
      max-width: 100%;
    }
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about-text p {
    color: var(--text-dim);
    line-height: 1.8;
  }

  .certifications, .zone {
    margin-top: var(--space-md);
  }

  .certifications h3, .zone h3 {
    font-size: 1rem;
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: .06em;
    color: var(--accent);
    margin-bottom: .5rem;
  }

  .certifications ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }

  .certifications li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--text-dim);
    font-size: .9rem;
  }

  .certifications li::before {
    content: '';
    position: absolute;
    left: 0;
    top: .55rem;
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
  }

  /* Values */
  .values {
    border-top: 1px solid var(--border);
  }

  .value-card {
    padding: var(--space-md);
    border: 1px solid var(--border);
    transition: border-color var(--transition);
  }

  .value-card:hover {
    border-color: var(--accent);
  }

  .value-number {
    font-family: var(--font-stat);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
    color: var(--accent);
    line-height: 1;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .value-card h3 {
    margin-bottom: .5rem;
  }

  .value-card p {
    font-size: .9rem;
  }
</style>
