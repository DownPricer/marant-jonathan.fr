---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Lightbox from '../../components/Lightbox.astro';
import projets from '../../data/projets.json';
import { withBase } from '../../utils/base';
import { labelCategorie } from '../../utils/categories';

export function getStaticPaths() {
  return projets.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const projet = projets.find((p) => p.slug === slug)!;
const media = (file: string) => withBase(`/images/projets/${projet.slug}/${file.replace(/\.(jpe?g|png)$/i, '.webp')}`);
const mediaOrig = (file: string) => withBase(`/images/projets/${projet.slug}/${file}`);
const categorieLabel = labelCategorie(projet.categorie);

type GalerieSection = {
  layout: 'hero' | 'grid';
  sousTitre?: string;
  note?: string;
  images: string[];
};

const rawSections = (projet as { galerieSections?: GalerieSection[] }).galerieSections;
const galerieSections = Array.isArray(rawSections) ? rawSections : null;

let photoCounter = 1;
const sectionsNumbered =
  galerieSections?.map((sec) => ({
    ...sec,
    numbered: sec.images.map((file) => ({ file, num: photoCounter++ })),
  })) ?? null;
---

<Layout
  title={projet.titre}
  description={projet.description}
  image={`/images/projets/${projet.slug}/${projet.couverture}`}
  ogType="article"
>
  <section class="page-header">
    <div class="container">
      <Breadcrumb crumbs={[
        { label: 'Réalisations', href: withBase('/realisations') },
        { label: projet.titre },
      ]} />
      <a href={withBase('/realisations')} class="back-link reveal">&larr; Retour aux réalisations</a>
      <p class="overline reveal">{categorieLabel} — {projet.lieu}, {projet.annee}</p>
      <h1 class="reveal">{projet.titre}</h1>
      <p class="projet-desc text-dim reveal">{projet.description}</p>
    </div>
  </section>

  {sectionsNumbered ? (
    sectionsNumbered.map((sec) =>
      sec.layout === 'hero' ? (
        <section class="projet-section projet-section--hero reveal">
          <div class="container">
            {sec.sousTitre && <h2 class="gallery-section-heading reveal">{sec.sousTitre}</h2>}
            {sec.note && <p class="gallery-section-note text-dim reveal">{sec.note}</p>}
          </div>
          <div class="projet-hero">
            {sec.numbered.map(({ file, num }) => (
              <div
                class="projet-hero-img reveal"
                style={`background-image:url(${JSON.stringify(media(file))})`}
                data-lightbox-src={mediaOrig(file)}
                data-lightbox-group={projet.slug}
                role="button"
                tabindex="0"
                aria-label={`Photo ${num} — voir en plein écran`}
              ></div>
            ))}
          </div>
        </section>
      ) : (
        <section class="section projet-gallery">
          <div class="container">
            {sec.sousTitre && <h2 class="gallery-section-heading reveal">{sec.sousTitre}</h2>}
            <div class="gallery-grid">
              {sec.numbered.map(({ file, num }, i) => (
                <div
                  class={`gallery-item ${i === 0 ? 'wide' : ''} reveal`}
                  style={`transition-delay: ${i * 0.06}s`}
                >
                  <div
                    class="gallery-img"
                    style={`background-image:url(${JSON.stringify(media(file))})`}
                    data-lightbox-src={mediaOrig(file)}
                    data-lightbox-group={projet.slug}
                    role="button"
                    tabindex="0"
                    aria-label={`Photo ${num} — voir en plein écran`}
                  ></div>
                </div>
              ))}
            </div>
          </div>
        </section>
      ),
    )
  ) : (
    <>
      <section class="projet-hero reveal">
        <div
          class="projet-hero-img"
          style={`background-image:url(${JSON.stringify(media(projet.images[0]))})`}
          data-lightbox-src={mediaOrig(projet.images[0])}
          data-lightbox-group={projet.slug}
          role="button"
          tabindex="0"
          aria-label="Voir en plein écran"
        ></div>
      </section>

      {projet.images.length > 1 && (
        <section class="section projet-gallery">
          <div class="container">
            <div class="gallery-grid">
              {projet.images.slice(1).map((img, i) => (
                <div
                  class={`gallery-item ${i === 0 ? 'wide' : ''} reveal`}
                  style={`transition-delay: ${i * 0.06}s`}
                >
                  <div
                    class="gallery-img"
                    style={`background-image:url(${JSON.stringify(media(img))})`}
                    data-lightbox-src={mediaOrig(img)}
                    data-lightbox-group={projet.slug}
                    role="button"
                    tabindex="0"
                    aria-label={`Photo ${i + 2} — voir en plein écran`}
                  ></div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}
    </>
  )}

  <!-- Video -->
  {projet.video && (
    <section class="section">
      <div class="container">
        <div
          class="projet-video reveal"
          data-lightbox-src={projet.video.startsWith('http') ? projet.video : withBase(projet.video.startsWith('/') ? projet.video : `/${projet.video}`)}
          data-lightbox-type="video"
          data-lightbox-group={`${projet.slug}-vid`}
        >
          <video src={projet.video.startsWith('http') ? projet.video : withBase(projet.video.startsWith('/') ? projet.video : `/${projet.video}`)} poster={media(projet.couverture)} preload="metadata"></video>
          <div class="video-play-overlay">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
              <circle cx="32" cy="32" r="31" stroke="currentColor" stroke-width="1.5"/>
              <polygon points="26,20 46,32 26,44" fill="currentColor"/>
            </svg>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section">
    <div class="container cta-bottom reveal">
      <h2>Un projet similaire ?</h2>
      <p class="text-dim">Parlons-en ensemble pour donner vie à vos idées.</p>
      <a href={withBase('/contact')} class="btn btn--filled">Demander un devis</a>
    </div>
  </section>

  <Lightbox />
</Layout>

<style>
  .page-header {
    padding-top: calc(var(--header-height) + var(--space-xl));
    padding-bottom: var(--space-lg);
  }

  .back-link {
    display: inline-block;
    font-size: .8rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: var(--space-md);
    transition: color var(--transition);
  }

  .back-link:hover { color: var(--accent); }

  .page-header h1 {
    margin-block: .5rem var(--space-sm);
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  .projet-desc {
    font-size: 1.05rem;
    max-width: 75ch;
  }

  .gallery-section-heading {
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    font-weight: 600;
    margin-block: 0 var(--space-xs);
    letter-spacing: -0.02em;
  }

  .projet-gallery .gallery-section-heading {
    margin-bottom: var(--space-md);
  }

  .gallery-section-note {
    margin: 0 0 var(--space-md);
    font-size: 1rem;
  }

  .projet-section--hero {
    padding-top: var(--space-sm);
  }

  .projet-section--hero .container {
    max-width: 1600px;
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  /* Hero image */
  .projet-hero {
    width: 100%;
    max-width: 1600px;
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .projet-hero-img {
    width: 100%;
    aspect-ratio: 21/9;
    background-size: cover;
    background-position: center;
    background-color: var(--surface);
    cursor: pointer;
    transition: transform .5s;
  }

  .projet-hero-img:hover {
    transform: scale(1.01);
  }

  /* Gallery grid — editorial layout */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery-item.wide {
      grid-column: span 2;
    }
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 3/2;
    background-size: cover;
    background-position: center;
    background-color: var(--surface);
    cursor: pointer;
    transition: transform .5s;
  }

  .gallery-item.wide .gallery-img {
    aspect-ratio: 21/9;
  }

  .gallery-img:hover {
    transform: scale(1.015);
  }

  /* Video */
  .projet-video {
    position: relative;
    cursor: pointer;
    max-width: 960px;
    margin-inline: auto;
  }

  .projet-video video {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    background: var(--surface);
  }

  .video-play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, .8);
    background: rgba(0, 0, 0, .3);
    transition: background .3s;
  }

  .projet-video:hover .video-play-overlay {
    background: rgba(0, 0, 0, .15);
  }

  /* Bottom CTA */
  .cta-bottom {
    text-align: center;
    padding-block: var(--space-lg);
    border-top: 1px solid var(--border);
  }

  .cta-bottom h2 {
    margin-bottom: .5rem;
  }

  .cta-bottom p {
    margin-inline: auto;
    margin-bottom: var(--space-md);
  }
</style>
