# URL publique du site (SEO, sitemap, JSON-LD)
SITE_URL=https://votre-domaine-exemple.fr

# Panneau d'administration local (npm run admin)
ADMIN_PASSWORD=votre-mot-de-passe-admin
ADMIN_PORT=3001

# Déploiement FTP OVH facultatif — copiez vers .env.deploy (non versionné)
# FTP_HOST=ftp.votre-domaine.fr
# FTP_USER=votre-login-ftp
# FTP_PASS=votre-mot-de-passe-ftp
# FTP_REMOTE=/www/
# FTP_PORT=21
# USE_SFTP=false
