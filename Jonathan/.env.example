# URL publique du site (SEO, sitemap, JSON-LD)
SITE_URL=https://marant-jonathan.fr

# Administration en production (/admin) — obligatoire
# Minimum 12 caractères pour ADMIN_PASSWORD, 32 pour SESSION_SECRET
ADMIN_PASSWORD=changez-moi-mot-de-passe-fort
SESSION_SECRET=changez-moi-secret-aleatoire-long-minimum-32-caracteres

# Stockage persistant (dans Docker : /data via volume)
DATA_DIR=./data

# Derrière Nginx / reverse proxy de confiance (VPS Docker)
TRUST_PROXY=true

# Taille max téléversement images (Mo)
MAX_UPLOAD_MB=10

# Nombre max de sauvegardes horodatées par fichier (site.json, projets.json)
MAX_BACKUPS=50

# Déploiement FTP OVH facultatif — copiez vers .env.deploy (non versionné)
# FTP_HOST=ftp.votre-domaine.fr
# FTP_USER=votre-login-ftp
# FTP_PASS=votre-mot-de-passe-ftp
# FTP_REMOTE=/www/
# FTP_PORT=21
# USE_SFTP=false

# En cas d'erreur npm UNABLE_TO_VERIFY_LEAF_SIGNATURE :
# - utiliser un réseau fiable ;
# - corriger le certificat racine du proxy/antivirus ;
# - mettre à jour Node.js et npm ;
# - ne pas désactiver la validation TLS (pas de strict-ssl=false).
